    "questionText": "<p>The remainder when $$7^{2022}+3^{2022}$$ is divided by 5 is :</p>",
    "options": [
      "0",
      "2",
      "3",
      "4"
    ],
    "correctOption": 2,
    "correctAnswer": null,
    "questionType": "MCQ",

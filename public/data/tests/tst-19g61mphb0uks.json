        "<img src=\"https://app-content.cdn.examgoal.net/fly/@width/image/jaoe38c1m6rjgg90/415d3b4f-d27d-4530-a8f0-2e65bc1f7bbf/f45c1750-e38b-11ef-8472-87722e2d9bfb/file-jaoe38c1m6rjgg91.png?format=png\" data-orsrc=\"https://app-content.cdn.examgoal.net/image/jaoe38c1m6rjgg90/415d3b4f-d27d-4530-a8f0-2e65bc1f7bbf/f45c1750-e38b-11ef-8472-87722e2d9bfb/file-jaoe38c1m6rjgg91.png\" loading=\"lazy\" style=\"max-width:100%;height:auto;display:block;margin:0 auto;max-height:40vh;vertical-align:baseline\" alt=\"JEE Main 2025 (Online) 22nd January Evening Shift Chemistry - Basics of Organic Chemistry Question 51 English Option 3\">",

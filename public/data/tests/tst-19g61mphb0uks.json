      "solution": "<img src=\"https://app-content.cdn.examgoal.net/fly/@width/image/6y3zli1lx57ijje/447c3571-f7c8-4e09-b094-a20e4cd82af7/10454ca0-2516-11ef-a928-e17283d8766b/file-6y3zli1lx57ijjf.png?format=png\" data-orsrc=\"https://app-content.cdn.examgoal.net/image/6y3zli1lx57ijje/447c3571-f7c8-4e09-b094-a20e4cd82af7/10454ca0-2516-11ef-a928-e17283d8766b/file-6y3zli1lx57ijjf.png\" loading=\"lazy\" style=\"max-width:100%;height:auto;display:block;margin:0 auto;max-height:40vh;vertical-align:baseline\" alt=\"JEE Main 2024 (Online) 4th April Morning Shift Chemistry - Basics of Organic Chemistry Question 79 English Explanation 1\">\n<img src=\"https://app-content.cdn.examgoal.net/fly/@width/image/6y3zli1lx57igtb/bfb61d02-c40f-45b7-86ad-949cec1bfdf3/0e2a82f0-2516-11ef-a928-e17283d8766b/file-6y3zli1lx57igtc.png?format=png\" data-orsrc=\"https://app-content.cdn.examgoal.net/image/6y3zli1lx57igtb/bfb61d02-c40f-45b7-86ad-949cec1bfdf3/0e2a82f0-2516-11ef-a928-e17283d8766b/file-6y3zli1lx57igtc.png\" loading=\"lazy\" style=\"max-width:100%;height:auto;display:block;margin:0 auto;max-height:40vh;vertical-align:baseline\" alt=\"JEE Main 2024 (Online) 4th April Morning Shift Chemistry - Basics of Organic Chemistry Question 79 English Explanation 2\">\n<img src=\"https://app-content.cdn.examgoal.net/fly/@width/image/6y3zli1lx57iehk/e0b25f6e-44de-4e46-b9a4-e0afdf49dd88/0c5e7580-2516-11ef-a928-e17283d8766b/file-6y3zli1lx57iehl.png?format=png\" data-orsrc=\"https://app-content.cdn.examgoal.net/image/6y3zli1lx57iehk/e0b25f6e-44de-4e46-b9a4-e0afdf49dd88/0c5e7580-2516-11ef-a928-e17283d8766b/file-6y3zli1lx57iehl.png\" loading=\"lazy\" style=\"max-width:100%;height:auto;display:block;margin:0 auto;max-height:40vh;vertical-align:baseline\" alt=\"JEE Main 2024 (Online) 4th April Morning Shift Chemistry - Basics of Organic Chemistry Question 79 English Explanation 3\">\n<img src=\"https://app-content.cdn.examgoal.net/fly/@width/image/6y3zli1lx57ic3u/50db0ba2-f226-4425-81ee-a6abedb46135/0a876b90-2516-11ef-a928-e17283d8766b/file-6y3zli1lx57ic3v.png?format=png\" data-orsrc=\"https://app-content.cdn.examgoal.net/image/6y3zli1lx57ic3u/50db0ba2-f226-4425-81ee-a6abedb46135/0a876b90-2516-11ef-a928-e17283d8766b/file-6y3zli1lx57ic3v.png\" loading=\"lazy\" style=\"max-width:100%;height:auto;display:block;margin:0 auto;max-height:40vh;vertical-align:baseline\" alt=\"JEE Main 2024 (Online) 4th April Morning Shift Chemistry - Basics of Organic Chemistry Question 79 English Explanation 4\">",

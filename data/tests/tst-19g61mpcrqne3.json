    {
      "id": "9PHB1DWhe3WP0H5p",
      "questionNumber": 3,
      "questionText": "If the ratio of the concentration of electrons to that of holes in a semiconductor is $${7 \\over 5}$$ and the ratio of currents is $${7 \\over 4},$$ then what is the ratio of their drift velocities? ",
      "options": [
        "$${5 \\over 8}$$ ",
        "$${4 \\over 5}$$",
        "$${5 \\over 4}$$",
        "$${4 \\over 7}$$"
      ],
      "correctOption": 2,
      "correctAnswer": null,
      "questionType": "MCQ",
      "marks": 4,
      "negativeMarks": -1,
      "subject": "Physics",
      "topic": "semiconductor-and-p-n-junction-diode",
      "difficulty": "Easy",
      "solution": "$${{{I_e}} \\over {{I_h}}} = {{n{}_eeA{v_e}} \\over {n{}_heA{v_h}}}$$\n<br><br>$$ \\Rightarrow {7 \\over 4} = {7 \\over 5} \\times {{{v_e}} \\over {{v_h}}}$$\n<br><br>$$ \\Rightarrow {{{v_e}} \\over {{v_h}}} = {5 \\over 4}$$",
      "section": "A",
      "instruction": "",
      "examSource": "jee-main"
    },

    {
      "id": "m6v43dav",
      "questionNumber": 6,
      "questionText": "<p>The hydrocarbon $(\\mathrm{X})$ with molar mass $80 \\mathrm{~g} \\mathrm{~mol}^{-1}$ and $90 \\%$ carbon has _______ degree of unsaturation.</p>",
      "options": [],
      "correctOption": 0,
      "correctAnswer": null,
      "questionType": "MCQ",
      "marks": 4,
      "negativeMarks": -1,
      "subject": "Chemistry",
      "topic": "iupac-nomenclature",
      "difficulty": "Easy",
      "solution": "<p>Mass of carbon $=\\frac{80 \\times 90}{100}=72 \\mathrm{gm}$</p>\n<p>Number of C-atoms $=\\frac{72}{12}=6$</p>\n<p>Mass of hydrogen $=\\frac{80 \\times 10}{800}=8 \\mathrm{gm}$</p>\n<p>Number of H -atoms $=\\frac{8}{1}=8$</p>\n<p>So molecular formula $\\mathrm{C}_6 \\mathrm{H}_8$</p>\n<p>D.U. $=6+1-8 / 2=7-4=3$</p>",
      "section": "A",
      "instruction": "",
      "examSource": "jee-main"
    },

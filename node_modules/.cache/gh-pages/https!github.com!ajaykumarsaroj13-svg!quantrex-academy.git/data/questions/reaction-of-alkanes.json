    "solution": "<p><style type=\"text/css\">\n.tg  {border-collapse:collapse;border-spacing:0;}\n.tg td{border-color:black;border-style:solid;border-width:1px;font-family:Arial, sans-serif;font-size:14px;\n  overflow:hidden;padding:10px 5px;word-break:normal;}\n.tg th{border-color:black;border-style:solid;border-width:1px;font-family:Arial, sans-serif;font-size:14px;\n  font-weight:normal;overflow:hidden;padding:10px 5px;word-break:normal;}\n.tg .tg-c3ow{border-color:inherit;text-align:center;vertical-align:top}\n.tg .tg-7btt{border-color:inherit;font-weight:bold;text-align:center;vertical-align:top}\n</style>\n<table class=\"tg\" style=\"undefined;table-layout: fixed; width: 726px\"><colgroup>\n<col style=\"width: 91px\">\n<col style=\"width: 209px\">\n<col style=\"width: 87px\">\n<col style=\"width: 339px\">\n</colgroup>\n<thead>\n  <tr>\n    <th class=\"tg-7btt\"></th>\n    <th class=\"tg-7btt\">LIST-i<br>Name reaction</th>\n    <th class=\"tg-7btt\"></th>\n    <th class=\"tg-7btt\">LIST-II<br>Product obtainable</th>\n  </tr></thead>\n<tbody>\n  <tr>\n    <td class=\"tg-c3ow\">(A)</td>\n    <td class=\"tg-c3ow\">Swarts reaction</td>\n    <td class=\"tg-c3ow\">(I)</td>\n    <td class=\"tg-c3ow\">$\\mathrm{Et}-\\mathrm{I} \\xrightarrow[\\mathrm{DMF}]{\\mathrm{KF}} \\mathrm{Et}-\\mathrm{F}$<br></td>\n  </tr>\n  <tr>\n    <td class=\"tg-c3ow\">(B)</td>\n    <td class=\"tg-c3ow\">Sandmeyer's reaction</td>\n    <td class=\"tg-c3ow\">(II)</td>\n    <td class=\"tg-c3ow\">$\\mathrm{PhN}_2^{\\oplus} \\mathrm{Cl}^{-} \\xrightarrow{\\mathrm{CuCN} / \\mathrm{KCN}} \\mathrm{PhCN}+\\mathrm{N}_2$</td>\n  </tr>\n  <tr>\n    <td class=\"tg-c3ow\">(C)</td>\n    <td class=\"tg-c3ow\">Wurtz Fittig reaction</td>\n    <td class=\"tg-c3ow\">(III)</td>\n    <td class=\"tg-c3ow\">$$<br>\\mathrm{Ph}-\\mathrm{Cl}+\\mathrm{EtCl} \\xrightarrow[\\text { ether }]{\\mathrm{Na}}<br>$$<br>$$<br>\\mathrm{Ph}-\\mathrm{Et}+\\mathrm{Ph}-\\mathrm{Ph}+\\mathrm{Et}-\\mathrm{Et}<br>$$</td>\n  </tr>\n  <tr>\n    <td class=\"tg-c3ow\">(D)</td>\n    <td class=\"tg-c3ow\">Finkelstein reaction</td>\n    <td class=\"tg-c3ow\">(IV)</td>\n    <td class=\"tg-c3ow\">$\\mathrm{Et}-\\mathrm{Cl} \\xrightarrow[\\text { acetone }]{\\mathrm{NaI}} \\mathrm{Et}-\\mathrm{I}+\\mathrm{NaCl}$</td>\n  </tr>\n</tbody></table></p>",

    {
      "id": "lv2es40d",
      "questionNumber": 5,
      "questionText": "<p>Correct order of stability of carbanion is :</p>\n<p><img src=\"https://app-content.cdn.examgoal.net/fly/@width/image/1lv1tgt4w/9d7f1ac1-84df-4b17-a92e-8f6d51fc4e50/578d4800-fba0-11ee-aecf-73c37d9c3a58/file-1lv1tgt4x.png?format=png\" data-orsrc=\"https://app-content.cdn.examgoal.net/image/1lv1tgt4w/9d7f1ac1-84df-4b17-a92e-8f6d51fc4e50/578d4800-fba0-11ee-aecf-73c37d9c3a58/file-1lv1tgt4x.png\" loading=\"lazy\" style=\"max-width:100%;height:auto;display:block;margin:0 auto;max-height:40vh;vertical-align:baseline\" alt=\"JEE Main 2024 (Online) 4th April Evening Shift Chemistry - Basics of Organic Chemistry Question 77 English\"></p>",
      "options": [
        "d > c > b > a",
        "c > b > d > a",
        "d > a > c > b",
        "a > b > c > d"
      ],
      "correctOption": 0,
      "correctAnswer": null,
      "questionType": "MCQ",
      "marks": 4,
      "negativeMarks": -1,
      "subject": "Chemistry",
      "topic": "stability-of-intermediate",
      "difficulty": "Easy",
      "solution": "<p>(d) is aromatic. So it is most stable.</p>\n<p>(a) is anti-aromatic. So it is least stable.</p>",
      "section": "A",
      "instruction": "",
      "examSource": "jee-main"

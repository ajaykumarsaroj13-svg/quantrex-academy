      "V<sub>1</sub> = V<sub>2</sub> and R<sub>1</sub> = 2R<sub>2</sub> = R<sub>3</sub>",
      "V<sub>1</sub> = 2V<sub>2</sub> and 2R<sub>1</sub> = 2R<sub>2</sub> = R<sub>3</sub>",
      "2V<sub>1</sub> = V<sub>2</sub> and 2R<sub>1</sub> = R<sub>2</sub> = R<sub>3</sub>"

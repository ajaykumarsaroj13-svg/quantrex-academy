          },
          {
            "content": "Statement - 1 is true and Statement - 2 is true; Statement - 2 is not a correct explanation for Statement - 1",
            "identifier": "B"
          },
          {
            "content": "Statement - 1 is True, Statement - 2 is False",
            "identifier": "C"
          },
          {

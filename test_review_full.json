              "en"
            ],
            "marks": 4,
            "negMarks": 1,
            "question": {
              "en": {
                "comprehension": null,
                "direction": null,
                "content": "<p>Moseley's equation for the determination of wavelength of X-rays is (<i>v</i> = frequency of wave, <i>Z</i> = nuclear charge, <i>a</i> and <i>b</i> are constants)</p>",
                "options": [
                  {
                    "identifier": "A",
                    "content": "<p>$\\sqrt{v} = Z - ab$</p>"
                  },
                  {
                    "identifier": "B",
                    "content": "<p>$v = a(Z - b)$</p>"
                  },
                  {
                    "identifier": "C",
                    "content": "<p>$\\sqrt{v} = a(Z - b)$</p>"
                  },
                  {
                    "identifier": "D",
                    "content": "<p>$v = Z - ab$</p>"
                  }
                ]
              },
              "hi": {
                "comprehension": null,
                "direction": null,
                "content": "<p>X-किरणों की तरंगदैर्ध्य के निर्धारण के लिए मोज़्ले (Moseley) का समीकरण है (<i>v</i> = तरंग की आवृत्ति, <i>Z</i> = नाभिकीय आवेश, <i>a</i> और <i>b</i> नियतांक हैं)</p>",
                "options": [
                  {
                    "identifier": "A",
                    "content": "<p>$\\sqrt{v} = Z - ab$</p>"
                  },
                  {
                    "identifier": "B",
                    "content": "<p>$v = a(Z - b)$</p>"
                  },
                  {
                    "identifier": "C",
                    "content": "<p>$\\sqrt{v} = a(Z - b)$</p>"
                  },
                  {
                    "identifier": "D",
                    "content": "<p>$v = Z - ab$</p>"
                  }
                ]
              }
            },
            "subTopic": null,
            "subject": "chemistry",
            "timeAllotted": 90000,
            "topic": "quantum-mechanical-model-of-atom",
            "type": "mcq"
          },
          {
            "questionId": "tq-mpzwipc4",
            "chapter": "structure-of-atom",
            "chapterGroup": "physical-chemistry",
            "country": "in",
            "difficulty": "easy",
            "exam": "jee-main",
            "examGroup": "jee",
